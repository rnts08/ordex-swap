ordexswap.online {
    reverse_proxy /api/* ordex-swap:8000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {header}
        header_up X-Forwarded-Proto {scheme}
    }
    
    reverse_proxy /health ordex-swap:8000
    
    reverse_proxy frontend:80 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {header}
        header_up X-Forwarded-Proto {scheme}
    }
    
    log {
        output file /data/access.log
    }
}
