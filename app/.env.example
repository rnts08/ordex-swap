# Secrets (do not commit real values)
NESTEX_API_KEY=your-nestex-api-key
NESTEX_API_SECRET=your-nestex-api-secret
OXC_RPC_USER=rpcuser
OXC_RPC_PASSWORD=rpcpassword
OXG_RPC_USER=rpcuser
OXG_RPC_PASSWORD=rpcpassword

# Service config
API_HOST=127.0.0.1
API_PORT=8000
TESTING_MODE=false
SWAP_CONFIRMATIONS_REQUIRED=1
DATA_DIR=/app/data
DB_PATH=/app/data/ordex.db
ORDEXCOIND_PATH=/app/data/bin/ordexcoind
ORDEXGOLDD_PATH=/app/data/bin/ordexgoldd
ORDEXCOIND_DATADIR=/app/data/oxc
ORDEXGOLDD_DATADIR=/app/data/oxg
OXC_RPC_URL=http://127.0.0.1:25173
OXG_RPC_URL=http://127.0.0.1:25465
